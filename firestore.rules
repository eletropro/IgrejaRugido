rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "duhgostozo@gmail.com");
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid || 
        isAdmin() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) && 
         request.resource.data.likes is number &&
         request.resource.data.likes == resource.data.likes + 1)
      );
      allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // Events collection
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Event Registrations
    match /event_registrations/{regId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Discipleship
    match /discipleship/{lessonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Config
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && configId == 'church' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dailyMessage']));
      allow create: if isAuthenticated(); // Allow first user to create default config if it doesn't exist
      allow delete: if isAdmin();
    }

    // Prayers collection
    match /prayers/{prayerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['intercessionCount']) && 
         request.resource.data.intercessionCount is number &&
         request.resource.data.intercessionCount == resource.data.intercessionCount + 1)
      );
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
  }
}
